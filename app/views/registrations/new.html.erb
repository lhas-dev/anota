<h2 class="text-xl font-bold text-slate-900 mb-1"><%= t("registrations.new.title") %></h2>
<p class="text-sm text-slate-500 mb-6"><%= t("registrations.new.subtitle") %></p>

<%= form_with model: @user, url: registration_path do |form| %>
  <div class="space-y-4">
    <div>
      <%= form.label :email_address, t("registrations.new.email_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
          placeholder: t("registrations.new.email_placeholder"),
          class: "w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition" %>
    </div>

    <div>
      <%= form.label :password, t("registrations.new.password_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password",
          placeholder: t("registrations.new.password_placeholder"), maxlength: 72,
          class: "w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition" %>
    </div>

    <div>
      <%= form.label :password_confirmation, t("registrations.new.password_confirmation_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
          placeholder: t("registrations.new.password_confirmation_placeholder"), maxlength: 72,
          class: "w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition" %>
    </div>

    <%= form.submit t("registrations.new.submit"),
        class: "w-full py-2.5 px-4 rounded-lg bg-slate-900 text-white text-sm font-semibold hover:bg-slate-700 transition-colors cursor-pointer mt-2" %>
  </div>
<% end %>

<p class="mt-5 text-center text-sm text-slate-500">
  <%= t("registrations.new.have_account") %>
  <%= link_to t("registrations.new.sign_in_link"), new_session_path, class: "font-medium text-slate-900 hover:underline" %>
</p>
