<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "Anota" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            },
          },
        },
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans bg-neutral-50 text-slate-900 antialiased min-h-screen flex flex-col">
    <div class="flex justify-end px-6 pt-4">
      <%= render "shared/locale_switcher" %>
    </div>

    <div class="flex-1 flex flex-col items-center justify-center px-4 py-8">
      <%= link_to root_path, class: "mb-8 text-2xl font-extrabold tracking-tight text-slate-900" do %>
        Anota
      <% end %>

      <div class="w-full max-w-sm bg-white border border-neutral-200 rounded-2xl p-8 shadow-sm">
        <% if flash[:alert] %>
          <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="mb-4 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </div>

    <footer class="py-6 text-center text-xs text-slate-400">
      &copy; <%= Time.current.year %> Anota. All rights reserved.
    </footer>
  </body>
</html>
