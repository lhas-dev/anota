<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "Anota" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            },
          },
        },
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..800&display=swap" rel="stylesheet">

    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans bg-neutral-100 text-slate-900 antialiased">
    <div class="flex h-screen overflow-hidden">

      <%# Sidebar — shadcn dark mode values %>
      <aside class="w-56 shrink-0 flex flex-col border-r" style="background:#18181b; border-color:#27272a;">

        <%# Brand %>
        <div class="flex items-center gap-2.5 px-4 h-14 border-b shrink-0" style="border-color:#27272a;">
          <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <%= link_to "Anota", root_path, class: "text-base font-semibold tracking-tight text-white" %>
        </div>

        <%# Nav %>
        <div class="flex-1 overflow-y-auto px-2 py-3">

          <%# Personal group %>
          <div class="mb-1 px-2.5 py-1">
            <span class="text-xs font-medium" style="color:#52525b;">Personal</span>
          </div>
          <ul class="space-y-0.5 mb-4">
            <%= render "layouts/dashboard/nav_item", icon: "habit",  label: t("dashboard.nav.habit_tracker"), path: habits_tracker_index_path %>
            <%= render "layouts/dashboard/nav_item", icon: "todos",  label: t("dashboard.nav.daily_todos"),   path: dashboard_path %>
            <%= render "layouts/dashboard/nav_item", icon: "agenda", label: t("dashboard.nav.agenda"),        path: dashboard_path %>
          </ul>

          <%# Separator %>
          <div class="mx-2 my-3" style="height:1px; background:#27272a;"></div>

          <%# Business group %>
          <div class="mb-1 px-2.5 py-1">
            <span class="text-xs font-medium" style="color:#52525b;">Business</span>
          </div>
          <ul class="space-y-0.5">
            <%= render "layouts/dashboard/nav_item", icon: "clients",  label: t("dashboard.nav.clients"),  path: dashboard_path %>
            <%= render "layouts/dashboard/nav_item", icon: "invoices", label: t("dashboard.nav.invoices"), path: dashboard_path %>
          </ul>

        </div>

        <%# Footer %>
        <div class="shrink-0 border-t px-2 py-3" style="border-color:#27272a;">
          <%# Locale switcher %>
          <div class="flex items-center gap-1 px-2.5 mb-2">
            <%= link_to "EN", url_for(locale: "en"),
                class: "text-xs px-1.5 py-0.5 rounded transition-colors",
                style: I18n.locale.to_s == "en" ? "color:#f4f4f5;background:#27272a;" : "color:#52525b;" %>
            <span style="color:#3f3f46;">/</span>
            <%= link_to "PT", url_for(locale: "pt-BR"),
                class: "text-xs px-1.5 py-0.5 rounded transition-colors",
                style: I18n.locale.to_s == "pt-BR" ? "color:#f4f4f5;background:#27272a;" : "color:#52525b;" %>
          </div>

          <%# User row %>
          <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-md" style="background:#27272a;">
            <div class="w-6 h-6 rounded-full shrink-0 flex items-center justify-center text-xs font-semibold text-white" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);">
              <%= Current.user.email_address.first.upcase %>
            </div>
            <span class="text-xs flex-1 truncate" style="color:#a1a1aa;"><%= Current.user.email_address %></span>
            <%= button_to session_path, method: :delete,
                class: "shrink-0 cursor-pointer rounded p-0.5 transition-colors hover:opacity-100",
                style: "background:transparent;",
                title: t("nav.sign_out") do %>
              <svg class="w-3.5 h-3.5" style="color:#52525b;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            <% end %>
          </div>
        </div>

      </aside>

      <%# Main content %>
      <main class="flex-1 overflow-y-auto">
        <% if flash[:alert] %>
          <div class="mx-6 mt-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="mx-6 mt-4 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>

        <%= yield %>
      </main>

    </div>
  </body>
</html>
