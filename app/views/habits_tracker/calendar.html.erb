<div class="px-8 py-8">
  <%# Header %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= t("habits_tracker.calendar") %></h1>
      <p class="text-slate-500 mt-1"><%= t("habits_tracker.calendar_subtitle") %></p>
    </div>
    <%= link_to habits_tracker_index_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <%= t("habits_tracker.back_to_tracker") %>
    <% end %>
  </div>

  <% if @habits.any? %>
    <%# Habit selector %>
    <div class="bg-white rounded-xl border border-slate-200 px-6 py-4 mb-6">
      <label class="block text-sm font-medium text-slate-700 mb-2"><%= t("habits_tracker.select_habit") %></label>
      <div class="flex flex-wrap gap-2">
        <% @habits.each do |habit| %>
          <% selected = @habit&.id == habit.id %>
          <%= link_to calendar_habits_tracker_index_path(habit_id: habit.id, month: @date&.month, year: @date&.year),
              class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-lg border transition-colors #{selected ? 'bg-indigo-50 border-indigo-300 text-indigo-700' : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50'}" do %>
            <div class="w-2.5 h-2.5 rounded-full" style="background-color: <%= habit.color || '#6366f1' %>;"></div>
            <%= habit.name %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @habit %>
      <%# Month navigation %>
      <div class="flex items-center justify-between mb-6">
        <% prev_date = @date - 1.month %>
        <% next_date = @date + 1.month %>
        <%= link_to calendar_habits_tracker_index_path(habit_id: @habit.id, month: prev_date.month, year: prev_date.year),
            class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <h2 class="text-lg font-semibold text-slate-900">
          <%= l(@date, format: "%B %Y") %>
        </h2>
        <%= link_to calendar_habits_tracker_index_path(habit_id: @habit.id, month: next_date.month, year: next_date.year),
            class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <%# Stats %>
      <div class="bg-white rounded-xl border border-slate-200 px-6 py-4 mb-6">
        <p class="text-sm text-slate-500">
          <%= t("habits_tracker.calendar_stats", tracked: @tracked_count, total: @days_in_month) %>
        </p>
        <div class="w-full bg-slate-100 rounded-full h-2 mt-2">
          <div class="h-2 rounded-full transition-all" style="width: <%= (@tracked_count.to_f / @days_in_month * 100).round %>%; background-color: <%= @habit.color || '#6366f1' %>;"></div>
        </div>
      </div>

      <%# Calendar grid %>
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <%# Day headers %>
        <div class="grid grid-cols-7 gap-1 mb-2">
          <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
            <div class="text-center text-xs font-medium text-slate-400 py-2"><%= t("habits_tracker.days.#{day.downcase}") %></div>
          <% end %>
        </div>

        <%# Calendar days %>
        <div class="grid grid-cols-7 gap-1">
          <%# Empty cells for offset %>
          <% @date.wday.times do %>
            <div class="aspect-square"></div>
          <% end %>

          <% (1..@days_in_month).each do |day| %>
            <% current_day = Date.new(@year, @month, day) %>
            <% tracked = @tracked_days.include?(current_day) %>
            <% is_today = current_day == Date.current %>
            <div class="aspect-square flex items-center justify-center rounded-lg text-sm font-medium transition-colors
              <%= if tracked
                    'text-white'
                  elsif is_today
                    'bg-slate-100 text-slate-900'
                  else
                    'text-slate-600'
                  end %>"
              style="<%= "background-color: #{@habit.color || '#6366f1'};" if tracked %>">
              <%= day %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16 bg-white rounded-xl border border-slate-200">
      <p class="text-slate-500"><%= t("habits_tracker.empty_title") %></p>
      <%= link_to new_habit_path, class: "inline-flex items-center gap-2 px-4 py-2 mt-4 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <%= t("habits_tracker.create_first") %>
      <% end %>
    </div>
  <% end %>
</div>
