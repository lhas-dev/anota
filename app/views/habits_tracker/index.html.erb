<div class="px-8 py-8">
  <%# Header %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= t("habits_tracker.title") %></h1>
      <p class="text-slate-500 mt-1"><%= t("habits_tracker.subtitle") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to calendar_habits_tracker_index_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <%= t("habits_tracker.calendar") %>
      <% end %>
      <%= link_to new_habit_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        <%= t("habits_tracker.new_habit") %>
      <% end %>
    </div>
  </div>

  <%# Score cards %>
  <div class="grid grid-cols-2 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-slate-200 px-6 py-4">
      <p class="text-sm text-slate-500"><%= t("habits_tracker.todays_score") %></p>
      <p class="text-3xl font-bold text-indigo-600 mt-1"><%= @todays_score %> <span class="text-base font-medium text-slate-400">pts</span></p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 px-6 py-4">
      <p class="text-sm text-slate-500"><%= t("habits_tracker.total_score") %></p>
      <p class="text-3xl font-bold text-emerald-600 mt-1"><%= @total_score %> <span class="text-base font-medium text-slate-400">pts</span></p>
    </div>
  </div>

  <%# Habits list %>
  <% if @habits.any? %>
    <div class="space-y-3" data-controller="sortable" data-sortable-url-value="<%= sort_habits_path %>">
      <% @habits.each do |habit| %>
        <% tracked = @todays_trackings[habit.id].present? %>
        <div class="flex items-center justify-between bg-white rounded-xl border border-slate-200 px-6 py-4 transition-all <%= 'ring-2 ring-emerald-200 border-emerald-300' if tracked %>" data-habit-id="<%= habit.id %>">
          <div class="flex items-center gap-4">
            <div data-sortable-handle class="cursor-grab active:cursor-grabbing text-slate-300 hover:text-slate-500 transition-colors shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
              </svg>
            </div>
            <div class="w-3 h-3 rounded-full shrink-0" style="background-color: <%= habit.color || '#6366f1' %>;"></div>
            <div>
              <p class="font-medium text-slate-900 <%= 'line-through text-slate-400' if tracked %>"><%= habit.name %></p>
              <% if habit.description.present? %>
                <p class="text-sm text-slate-500 mt-0.5"><%= habit.description %></p>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <% if tracked %>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-emerald-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                +10 pts
              </span>
              <%= button_to habit_tracking_path(habit), method: :delete, class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-500 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors cursor-pointer" do %>
                <%= t("habits_tracker.undo") %>
              <% end %>
            <% else %>
              <%= button_to habit_tracking_path(habit), method: :post, class: "inline-flex items-center gap-1 px-4 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <%= t("habits_tracker.mark_done") %>
              <% end %>
            <% end %>
            <%= link_to edit_habit_path(habit), class: "p-1.5 text-slate-400 hover:text-slate-600 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# Empty state %>
    <div class="text-center py-16 bg-white rounded-xl border border-slate-200">
      <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
      <h3 class="text-lg font-medium text-slate-900 mb-1"><%= t("habits_tracker.empty_title") %></h3>
      <p class="text-slate-500 mb-6"><%= t("habits_tracker.empty_description") %></p>
      <%= link_to new_habit_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        <%= t("habits_tracker.create_first") %>
      <% end %>
    </div>
  <% end %>

  <%# Manage habits link %>
  <% if @habits.any? %>
    <div class="mt-6 text-center">
      <%= link_to habits_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" do %>
        <%= t("habits_tracker.manage_habits") %>
      <% end %>
    </div>
  <% end %>
</div>
