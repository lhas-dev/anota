<div style="font-family: 'Inter', -apple-system, sans-serif; max-width: 600px; margin: 0 auto; padding: 32px 24px; color: #1e293b;">
  <div style="text-align: center; margin-bottom: 32px;">
    <div style="display: inline-block; width: 40px; height: 40px; border-radius: 8px; background: linear-gradient(135deg, #6366f1, #8b5cf6); line-height: 40px; text-align: center; margin-bottom: 12px;">
      <span style="color: white; font-weight: bold; font-size: 18px;">A</span>
    </div>
    <h1 style="font-size: 24px; font-weight: 700; margin: 0;"><%= t("habits_mailer.daily_report.subject") %></h1>
  </div>

  <p style="font-size: 16px; color: #475569;"><%= t("habits_mailer.daily_report.greeting") %></p>
  <p style="font-size: 14px; color: #64748b;"><%= t("habits_mailer.daily_report.summary", date: l(@date, format: :long)) %></p>

  <%# Score summary %>
  <div style="display: flex; gap: 16px; margin: 24px 0;">
    <div style="flex: 1; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 16px; text-align: center;">
      <p style="font-size: 12px; color: #64748b; margin: 0 0 4px;"><%= t("habits_mailer.daily_report.todays_score") %></p>
      <p style="font-size: 28px; font-weight: 700; color: #4f46e5; margin: 0;"><%= @todays_score %> pts</p>
    </div>
    <div style="flex: 1; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 16px; text-align: center;">
      <p style="font-size: 12px; color: #64748b; margin: 0 0 4px;"><%= t("habits_mailer.daily_report.total_score") %></p>
      <p style="font-size: 28px; font-weight: 700; color: #059669; margin: 0;"><%= @total_score %> pts</p>
    </div>
  </div>

  <%# Completed habits %>
  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #059669;">
      &#9989; <%= t("habits_mailer.daily_report.completed") %> (<%= @completed.size %>)
    </h2>
    <% if @completed.any? %>
      <% @completed.each do |habit| %>
        <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #f0fdf4; border-radius: 8px; margin-bottom: 6px;">
          <div style="width: 10px; height: 10px; border-radius: 50%; background-color: <%= habit.color || '#6366f1' %>;"></div>
          <span style="font-size: 14px; color: #1e293b;"><%= habit.name %></span>
          <span style="font-size: 12px; color: #059669; margin-left: auto;">+10 pts</span>
        </div>
      <% end %>
    <% else %>
      <p style="font-size: 14px; color: #94a3b8; font-style: italic;"><%= t("habits_mailer.daily_report.no_habits_completed") %></p>
    <% end %>
  </div>

  <%# Missed habits %>
  <div style="margin-bottom: 32px;">
    <h2 style="font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #dc2626;">
      &#10060; <%= t("habits_mailer.daily_report.missed") %> (<%= @missed.size %>)
    </h2>
    <% if @missed.any? %>
      <% @missed.each do |habit| %>
        <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #fef2f2; border-radius: 8px; margin-bottom: 6px;">
          <div style="width: 10px; height: 10px; border-radius: 50%; background-color: <%= habit.color || '#6366f1' %>;"></div>
          <span style="font-size: 14px; color: #1e293b;"><%= habit.name %></span>
        </div>
      <% end %>
    <% else %>
      <p style="font-size: 14px; color: #059669; font-style: italic;"><%= t("habits_mailer.daily_report.no_habits_missed") %></p>
    <% end %>
  </div>

  <%# CTA %>
  <div style="text-align: center; margin-bottom: 32px;">
    <%= link_to t("habits_mailer.daily_report.view_tracker"), habits_tracker_index_url, style: "display: inline-block; padding: 12px 24px; background: #4f46e5; color: white; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600;" %>
  </div>

  <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 24px 0;">
  <p style="font-size: 12px; color: #94a3b8; text-align: center;"><%= t("habits_mailer.daily_report.footer") %></p>
</div>
