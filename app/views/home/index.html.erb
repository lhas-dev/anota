<%# Navbar %>
<header class="border-b border-neutral-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <span class="text-xl font-bold tracking-tight text-slate-900">Anota</span>
    <a href="#" class="inline-flex items-center px-4 py-2 rounded-lg bg-slate-900 text-white text-sm font-medium hover:bg-slate-700 transition-colors">
      Get started
    </a>
  </div>
</header>

<%# Hero %>
<section class="max-w-6xl mx-auto px-6 pt-24 pb-20 text-center">
  <h1 class="text-6xl font-extrabold tracking-tight text-slate-900 leading-tight mb-6">
    Own your day.
  </h1>
  <p class="text-xl text-slate-500 max-w-2xl mx-auto mb-10 leading-relaxed">
    Anota brings your habits, tasks, agenda, and invoices into one clean workspace — so you can focus on what matters.
  </p>
  <div class="flex items-center justify-center gap-4 flex-wrap">
    <a href="#" class="inline-flex items-center px-6 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-700 transition-colors text-base">
      Get started — it's free
    </a>
    <a href="#features" class="inline-flex items-center px-6 py-3 rounded-xl border border-neutral-200 text-slate-700 font-semibold hover:bg-neutral-50 transition-colors text-base">
      Learn more ↓
    </a>
  </div>
</section>

<%# Features grid %>
<section id="features" class="max-w-6xl mx-auto px-6 pb-24">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

    <%# Habit Tracker %>
    <div class="rounded-xl border border-neutral-200 bg-white p-6 hover:shadow-md transition-shadow">
      <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
      </div>
      <h3 class="font-semibold text-slate-900 mb-1">Habit Tracker</h3>
      <p class="text-sm text-slate-500">Build streaks and track daily habits that compound over time.</p>
    </div>

    <%# To-Do Lists %>
    <div class="rounded-xl border border-neutral-200 bg-white p-6 hover:shadow-md transition-shadow">
      <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      </div>
      <h3 class="font-semibold text-slate-900 mb-1">To-Do Lists</h3>
      <p class="text-sm text-slate-500">Capture tasks and stay on top of everything that needs doing.</p>
    </div>

    <%# Agenda %>
    <div class="rounded-xl border border-neutral-200 bg-white p-6 hover:shadow-md transition-shadow">
      <div class="w-10 h-10 rounded-lg bg-violet-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <h3 class="font-semibold text-slate-900 mb-1">Agenda</h3>
      <p class="text-sm text-slate-500">Plan your week with a clean calendar view of what's coming up.</p>
    </div>

    <%# Invoice Generator %>
    <div class="rounded-xl border border-neutral-200 bg-white p-6 hover:shadow-md transition-shadow">
      <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h3 class="font-semibold text-slate-900 mb-1">Invoice Generator</h3>
      <p class="text-sm text-slate-500">Create and send professional invoices to clients in seconds.</p>
    </div>

  </div>
</section>

<%# Footer %>
<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="max-w-6xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500">
    <span class="font-semibold text-slate-700">Anota</span>
    <span>&copy; <%= Time.current.year %> Anota. All rights reserved.</span>
  </div>
</footer>
