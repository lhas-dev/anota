<h2 class="text-xl font-bold text-slate-900 mb-1"><%= t("sessions.new.title") %></h2>
<p class="text-sm text-slate-500 mb-6"><%= t("sessions.new.subtitle") %></p>

<%= form_with url: session_path do |form| %>
  <div class="space-y-4">
    <div>
      <%= form.label :email_address, t("sessions.new.email_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
          placeholder: t("sessions.new.email_placeholder"), value: params[:email_address],
          class: "w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition" %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <%= form.label :password, t("sessions.new.password_label"), class: "block text-sm font-medium text-slate-700" %>
        <%= link_to t("sessions.new.forgot_password"), new_password_path, class: "text-xs text-slate-500 hover:text-slate-900 hover:underline" %>
      </div>
      <%= form.password_field :password, required: true, autocomplete: "current-password",
          placeholder: t("sessions.new.password_placeholder"), maxlength: 72,
          class: "w-full px-3 py-2 rounded-lg border border-neutral-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition" %>
    </div>

    <%= form.submit t("sessions.new.submit"),
        class: "w-full py-2.5 px-4 rounded-lg bg-slate-900 text-white text-sm font-semibold hover:bg-slate-700 transition-colors cursor-pointer mt-2" %>
  </div>
<% end %>

<p class="mt-5 text-center text-sm text-slate-500">
  <%= t("sessions.new.no_account") %>
  <%= link_to t("sessions.new.sign_up_link"), new_registration_path, class: "font-medium text-slate-900 hover:underline" %>
</p>
